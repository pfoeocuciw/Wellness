## Required
# Postgres connection for Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/cursach_db?schema=public"

# Used for JWT auth signing/verifying
JWT_SECRET="change_me_long_random_secret"

## Email (required for register/verify flows)
SMTP_HOST="smtp.example.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="user@example.com"
SMTP_PASS="app_password_or_smtp_password"
SMTP_FROM="Wellness <no-reply@example.com>"

## CORS
# Comma-separated list of allowed origins in production
# Example: https://wellness.example.com,https://admin.wellness.example.com
CORS_ORIGINS="http://localhost:3000"

## Optional flags
# WARNING: keep false in production
DEBUG_AUTH_NO_EMAIL="false"
SEED_DB_ON_START="false"
RSS_IMPORT_ON_START="true"
RSS_SCHEDULER_ENABLED="true"

