datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                Int       @id @default(autoincrement())
  email             String    @unique
  password          String
  first_name        String
  last_name         String
  role              String
  is_verified       Boolean   @default(false)
  diploma_info      String?
  bio               String?
  created_at        DateTime  @default(now())
  deleted_flag      String?

  is_email_verified Boolean   @default(false)
  email_verified_at DateTime?

  verification_codes EmailVerificationCode[]
  interesting_categories UserInterestingCategory[]
}

model EmailVerificationCode {
  id         Int      @id @default(autoincrement())
  user_id    Int
  email      String
  code       String
  expires_at DateTime
  used       Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([email])
  @@map("email_verification_codes")
}

model UserInterestingCategory {
  user_id     Int
  category_id Int

  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [category_id], references: [id], onDelete: Cascade)

  @@id([user_id, category_id])
  @@map("user_interesting_categories")
}

model Category {
  id               Int                       @id @default(autoincrement())
  name             String
  description      String?

  interested_users UserInterestingCategory[]

  @@map("categories")
}

model Article {
  id           String   @id @default(uuid())
  title        String
  slug         String   @unique
  authorName   String
  authorBio    String?
  category     String
  annotation   String   @db.Text
  imageUrl     String
  imageAlt     String
  content      Json
  sources      Json
  createdAt    DateTime @default(now())
  published    Boolean  @default(true)

  // поля для RSS
  externalUrl  String?  @unique
  sourceSite   String?
  sourceRssUrl String?
  guid         String?
  rawHtml      String?
  importedAt   DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ImportRun {
  id         String   @id @default(uuid())
  jobName    String
  status     String
  trigger    String?
  startedAt  DateTime @default(now())
  finishedAt DateTime?
  message    String?
  createdAt  DateTime @default(now())

  @@index([jobName, status, startedAt])
}